---
import '../styles/global.css';
import Analytics from '../components/Analytics.astro';
import { about, brand, contact, invoice, siteMeta } from '../content/site';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
}

const {
  title = siteMeta.title,
  description = siteMeta.description,
  canonicalUrl: canonicalUrlProp,
} = Astro.props;

/** 公開ルート（末尾スラッシュありになりがちだが canonical は正規化して使用） */
const rootHref =
  Astro.site != null
    ? new URL(import.meta.env.BASE_URL, Astro.site).href.replace(/\/?$/, '/')
    : siteMeta.siteUrl.replace(/\/?$/, '/');

const canonicalUrl = (canonicalUrlProp ?? rootHref).replace(/\/?$/, '/');

const ogImageUrl = new URL(siteMeta.ogImagePath.replace(/^\//, ''), rootHref).href;

/** 木津川市役所付近のおおよその座標（ローカル検索の補助） */
const kizugawaGeo = { latitude: 34.7361, longitude: 135.8206 };

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${canonicalUrl}#website`,
      url: canonicalUrl,
      name: brand.name,
      description,
      inLanguage: 'ja-JP',
      publisher: { '@id': `${canonicalUrl}#business` },
    },
    {
      '@type': 'ProfessionalService',
      '@id': `${canonicalUrl}#business`,
      name: 'AsaiTech',
      description,
      url: canonicalUrl,
      image: ogImageUrl,
      address: {
        '@type': 'PostalAddress',
        addressLocality: '木津川市',
        addressRegion: '京都府',
        addressCountry: 'JP',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: kizugawaGeo.latitude,
        longitude: kizugawaGeo.longitude,
      },
      areaServed: [
        {
          '@type': 'City',
          name: '木津川市',
          containedInPlace: { '@type': 'AdministrativeArea', name: '京都府' },
        },
        { '@type': 'AdministrativeArea', name: '京都府' },
        { '@type': 'AdministrativeArea', name: '大阪府' },
        { '@type': 'AdministrativeArea', name: '奈良県' },
        { '@type': 'AdministrativeArea', name: '滋賀県' },
        { '@type': 'AdministrativeArea', name: '兵庫県' },
        { '@type': 'Country', name: 'Japan' },
      ],
      knowsAbout: [
        'ホームページ制作',
        'Webサイト制作',
        'コーポレートサイト',
        'レスポンシブデザイン',
        'フロントエンド開発',
      ],
      email: contact.email.address,
      sameAs: [contact.github.url, contact.blog.url],
      ...(invoice.registrationNumber ? { taxID: invoice.registrationNumber } : {}),
    },
  ],
};

const iconBase = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0f172a" />
    <link rel="icon" href={`${iconBase}favicon.ico`} sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href={`${iconBase}favicon-32x32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${iconBase}favicon-16x16.png`} />
    <link rel="icon" type="image/svg+xml" href={`${iconBase}favicon.svg`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${iconBase}apple-touch-icon.png`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={siteMeta.keywords} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="ja" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brand.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={siteMeta.ogLocale} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={about.photo.alt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body
    class="min-h-dvh bg-white font-sans text-slate-900 antialiased [font-feature-settings:'palt']"
  >
    <slot />
    <Analytics />
  </body>
</html>
