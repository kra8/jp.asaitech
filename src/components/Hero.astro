---
import Icon from './Icon.astro';
import { analyticsEvents } from '../lib/analytics-events';
import { brand } from '../content/site';

const introClass =
  'text-pretty text-base leading-readable text-slate-600 md:text-lg md:leading-readable-lg';
const heroMeasureClass = 'w-full max-w-2xl';
const { primary, secondary } = brand.heroCtas;
---

<section
  id="hero"
  aria-labelledby="hero-heading"
  class="relative overflow-hidden border-b border-slate-100 bg-gradient-to-b from-white via-white to-slate-50/80 py-20 md:py-28 lg:py-32"
>
  <div
    class="animate-hero-line pointer-events-none absolute inset-x-0 top-0 h-px origin-center bg-gradient-to-r from-transparent via-sky-300/80 to-transparent"
    aria-hidden="true"
  />
  <div class="relative z-[1] mx-auto max-w-5xl px-4 sm:px-6">
    <div class:list={[heroMeasureClass, 'flex flex-col gap-5 md:gap-6']}>
      <p class="m-0 w-full animate-hero-in">
        <span
          class="inline-flex max-w-full items-center rounded-full border border-sky-200/80 bg-sky-50 px-3 py-1 text-xs font-semibold tracking-wide text-sky-900"
        >
          {brand.heroBadge}
        </span>
      </p>
      <h1
        id="hero-heading"
        class="animate-hero-in animate-hero-delay-1 w-full text-pretty text-3xl font-semibold leading-normal tracking-tight text-slate-900 md:text-[2.125rem] md:leading-snug"
      >
        {brand.heroHeading}
      </h1>
      <p
        class="animate-hero-in animate-hero-delay-2 m-0 w-full text-pretty text-lg font-medium leading-snug text-slate-700 md:text-xl md:leading-snug"
      >
        {brand.tagline}
      </p>
      <p
        class="animate-hero-in animate-hero-delay-3 m-0 w-full text-pretty text-base font-medium leading-readable text-slate-600 md:text-lg"
      >
        {brand.heroLead}
      </p>
      <div class="flex w-full flex-col gap-4 md:gap-5">
        {
          brand.introParagraphs.map((text, i) => (
            <p
              class:list={[
                introClass,
                'm-0 w-full animate-hero-in',
                i === 0 ? 'animate-hero-delay-4' : 'animate-hero-delay-5',
              ]}
            >
              {text}
            </p>
          ))
        }
      </div>
      <div
        class="animate-hero-in animate-hero-delay-5 flex w-full flex-col gap-3 pt-2 sm:flex-row sm:flex-wrap sm:items-center sm:gap-4"
      >
        <div class="flex flex-col gap-2">
          <a
            href={primary.href}
            data-analytics-click={analyticsEvents.heroCtaClick}
            class="motion-safe:hover:-translate-y-px inline-flex min-h-12 min-w-[11rem] items-center justify-center gap-2 rounded-xl bg-sky-900 px-7 py-3.5 text-base font-semibold text-white shadow-md outline-none transition-[background-color,transform,box-shadow] duration-200 hover:bg-sky-950 hover:shadow-lg motion-safe:active:translate-y-px focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-800"
          >
            <Icon name="mail" size={18} class="opacity-95" />
            {primary.label}
          </a>
          <p class="m-0 text-sm leading-readable text-slate-500">{brand.heroCtaNote}</p>
        </div>
        <a
          href={secondary.href}
          data-analytics-click={analyticsEvents.heroSecondaryClick}
          class="motion-safe:hover:-translate-y-px inline-flex min-h-11 min-w-[10rem] items-center justify-center gap-2 self-start rounded-xl border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-800 outline-none transition-[border-color,background-color,transform,box-shadow] duration-200 hover:border-slate-300 hover:bg-slate-50 hover:shadow-sm motion-safe:active:translate-y-px focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-800 sm:self-center"
        >
          <Icon name="layout-template" size={17} class="text-slate-500" />
          {secondary.label}
        </a>
      </div>
    </div>
  </div>
</section>
