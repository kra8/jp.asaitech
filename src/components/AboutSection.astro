---
import { Image } from 'astro:assets';
import Section from './Section.astro';
import { about } from '../content/site';
import dogPhoto from '../assets/asai-dog.png';

const paragraphClass =
  'm-0 text-pretty text-base leading-readable text-slate-600 md:text-lg md:leading-readable-lg';
---

<Section id="about" title={about.title} lead={about.lead}>
  <div
    class="flex flex-col gap-10 lg:flex-row lg:items-start lg:gap-12 xl:gap-14"
  >
    <div
      class="flex min-w-0 flex-1 flex-col gap-6 md:gap-7"
      data-stagger-children
    >
      {about.paragraphs.map((p) => (
        <p class={paragraphClass}>{p}</p>
      ))}
    </div>

    <figure
      class="motion-safe:transition-opacity motion-safe:duration-500 mx-auto w-full max-w-[min(100%,280px)] shrink-0 lg:mx-0 lg:w-[220px] lg:max-w-none xl:w-[240px]"
    >
      <div
        class="overflow-hidden rounded-2xl shadow-[0_12px_40px_rgb(15_23_42_/_.09)] ring-1 ring-slate-200/90 motion-safe:lg:hover:-translate-y-0.5 motion-safe:transition-transform motion-safe:duration-300"
      >
        <Image
          src={dogPhoto}
          alt={about.photo.alt}
          widths={[280, 440, 520]}
          sizes="(max-width: 1023px) min(90vw, 280px), 220px"
          class="aspect-[4/3] h-auto w-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
      <figcaption class="mt-3 text-center text-xs leading-normal text-slate-500 lg:text-left">
        {about.photo.caption}
      </figcaption>
    </figure>
  </div>
</Section>
