---
interface Props {
  tag?: 'li' | 'div' | 'article';
  class?: string;
}

const { tag: Tag = 'div', class: className = '' } = Astro.props;

const base =
  'motion-safe:hover:-translate-y-0.5 flex h-full flex-col rounded-2xl border border-slate-200/90 bg-white p-6 shadow-[0_1px_2px_rgb(15_23_42_/_.05)] motion-safe:transition motion-safe:duration-200 motion-safe:ease-out hover:border-slate-300 hover:shadow-[0_10px_28px_rgb(15_23_42_/_.07)] focus-within:border-slate-300 focus-within:shadow-[0_10px_28px_rgb(15_23_42_/_.07)] motion-safe:active:translate-y-0';
---

<Tag class:list={[base, className]}>
  <slot />
</Tag>
