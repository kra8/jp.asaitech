---
import SurfaceCard from './SurfaceCard.astro';
import Section from './Section.astro';
import { works } from '../content/site';

const cardDescClass =
  'm-0 mt-4 flex-1 text-sm leading-readable text-slate-600 md:text-base md:leading-readable-lg';

type WorkItem = (typeof works.items)[number];
---

<Section id="works" title={works.title} lead={works.lead}>
  <ul class="m-0 grid list-none gap-6 p-0 md:grid-cols-2 md:gap-7" data-stagger-children>
    {
      works.items.map((item: WorkItem) => (
        <SurfaceCard tag="li" class="md:p-7">
          <h3 class="m-0 text-lg font-semibold leading-snug tracking-tight text-slate-900">
            {
              item.url ? (
                <a
                  href={item.url}
                  class="rounded-md text-inherit underline decoration-sky-300 underline-offset-[5px] transition-colors hover:text-sky-950 hover:decoration-sky-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-800"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {item.title}
                  <span class="sr-only">（新しいタブで開きます）</span>
                </a>
              ) : (
                item.title
              )
            }
          </h3>
          {
            'categories' in item && item.categories.length > 0 && (
              <ul
                class="m-0 mt-3 flex list-none flex-wrap gap-2 p-0"
                aria-label="カテゴリ"
              >
                {item.categories.map((label) => (
                  <li class="m-0">
                    <span class="inline-flex rounded-full border border-sky-200/90 bg-sky-50 px-2.5 py-0.5 text-xs font-medium leading-normal text-sky-950">
                      {label}
                    </span>
                  </li>
                ))}
              </ul>
            )
          }
          <p class={cardDescClass}>{item.description}</p>
        </SurfaceCard>
      ))
    }
  </ul>
</Section>
